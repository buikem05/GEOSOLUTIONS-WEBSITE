# Apache config for the php/ directory
# Ensures JSON APIs work cleanly and prevents direct directory listing

Options -Indexes

# Allow cross-origin requests (belt-and-suspenders alongside PHP headers)
<IfModule mod_headers.c>
    Header always set Access-Control-Allow-Origin "*"
    Header always set Access-Control-Allow-Methods "GET, POST, PATCH, DELETE, OPTIONS"
    Header always set Access-Control-Allow-Headers "Content-Type, Authorization"
</IfModule>

# Pretty error pages → JSON (stops Apache HTML error pages breaking JSON parsing)
ErrorDocument 404 /php/api/_404.php
ErrorDocument 500 /php/api/_500.php
