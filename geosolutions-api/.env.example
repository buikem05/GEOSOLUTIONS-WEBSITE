# Application Environment
NODE_ENV=development
PORT=3001
LOG_LEVEL=info
FRONTEND_URL=http://localhost:3000

# Database (Prisma)
DATABASE_URL="mysql://root@localhost:3306/geo_academy_db"

# Redis Cache & Distributed Rate Limiting
REDIS_URL="redis://localhost:6379"

# Security Secrets (Token Rotation)
JWT_ACCESS_SECRET="enterprise-super-secret-access-key-minimum-32-chars-long"
JWT_REFRESH_SECRET="enterprise-super-secret-refresh-key-minimum-32-chars-long"

# AI Microservice Boundary (Python / FastAPI)
AI_SERVICE_URL="http://localhost:8000/api/v1"
